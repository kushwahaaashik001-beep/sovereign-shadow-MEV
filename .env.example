# The Sovereign Shadow - Environment Configuration
# Copy to .env and customize

# RPC Endpoints (L2 priority for Pillar O)
SHADOW_WS_URL=ws://localhost:8546
SHADOW_RPC_URL=http://localhost:8546
CHAIN=base  # mainnet | base | arbitrum

# Wallet (Anvil default for testing)
SHADOW_PRIVATE_KEY
SHADOW_FLASHBOTS_IDENTITY

# Executor (deploy your own for production)
EXECUTOR_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Switches
VETO_SWITCH=0  # Set=1 for watch-only (Pillar V)

# Production Example (Base + Alchemy)
# SHADOW_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# CHAIN=base

